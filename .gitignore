# Personal — never commit
operator/

# Staging — unprocessed content
raw_dropzone/

# Obsidian UI state (keep config, not workspace)
.obsidian/workspace*.json
.obsidian/workspace.json
.obsidian/cache
.obsidian/plugins/*/data.json

# macOS noise
.DS_Store
**/.DS_Store

# Editor swap files
*.swp
*.tmp
*~

# Anything explicitly marked private
*.private.md
**/private/

# Log files — regenerable, noisy diffs, not history-worthy
*.log
**/*.log

# Inbox is staging by design — items flow through, audit_log captures the events
projects/aiteam/inbox/
